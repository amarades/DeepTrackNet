# CrowdSafe AI — Backend Environment Variables
# Copy to .env and fill in values

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=CrowdSafe AI
APP_VERSION=1.0.0
DEBUG=true
SIMULATION_MODE=true

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=dev-secret-key-change-in-production-123456789
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite for local dev (no PostgreSQL needed):
# DATABASE_URL=sqlite+aiosqlite:///./crowdsafe.db
# PostgreSQL (Docker):
DATABASE_URL=postgresql+asyncpg://crowd:crowdpass@localhost:5432/crowdsafe
DATABASE_URL_SYNC=postgresql://crowd:crowdpass@localhost:5432/crowdsafe

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Crowd Thresholds ──────────────────────────────────────────────────────────
DENSITY_LOW_THRESHOLD=0.3
DENSITY_MEDIUM_THRESHOLD=0.55
DENSITY_HIGH_THRESHOLD=0.75
DENSITY_CRITICAL_THRESHOLD=0.90
COUNT_MEDIUM_THRESHOLD=50
COUNT_HIGH_THRESHOLD=100
COUNT_CRITICAL_THRESHOLD=200

# ── Notifications (optional) ──────────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASSWORD=your-app-password
# ALERT_EMAIL_RECIPIENTS=["security@yourdomain.com"]
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# TELEGRAM_CHAT_IDS=["-100xxxxxxxxxx"]
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_FROM_NUMBER=+1234567890
